---
import type { SiteConfigMap } from '../lib/site-config';

export interface Props {
  configs: SiteConfigMap;
}

const { configs } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="navbar">
  <div class="navbar-inner">
    <a href={base} class="navbar-logo">
      <svg width="32" height="32" viewBox="0 0 54 54" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="8" width="44" height="44" fill="#000000" />
        <rect x="2" y="2" width="44" height="44" fill="#ffd400" stroke="#000000" stroke-width="4" />
        <rect x="16" y="16" width="16" height="16" fill="#000000" />
      </svg>
      <span>HookBloq</span>
    </a>
    <nav>
      <ul class="navbar-links" id="navbarLinks">
        <li><a href={`${base}#servicios`} class="navbar-link">Servicios</a></li>
        <li><a href={`${base}#proceso`} class="navbar-link">Proceso</a></li>
        <li><a href={`${base}#tecnologias`} class="navbar-link">Tecnologias</a></li>
        <li><a href={`${base}blog`} class="navbar-link">Blog</a></li>
        <li><a href={`${base}#contacto`} class="navbar-link">Contacto</a></li>
      </ul>
    </nav>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <i class="bi bi-list"></i>
    </button>
  </div>
  <div class="nav-overlay" id="navOverlay"></div>
</header>

<script>
  (function () {
    const toggle = document.getElementById('navToggle');
    const links = document.getElementById('navbarLinks');
    const overlay = document.getElementById('navOverlay');

    if (!toggle || !links || !overlay) return;

    function open() {
      links.classList.add('open');
      overlay.classList.add('open');
      toggle.innerHTML = '<i class="bi bi-x-lg"></i>';
    }

    function close() {
      links.classList.remove('open');
      overlay.classList.remove('open');
      toggle.innerHTML = '<i class="bi bi-list"></i>';
    }

    toggle.addEventListener('click', function () {
      if (links.classList.contains('open')) {
        close();
      } else {
        open();
      }
    });

    overlay.addEventListener('click', close);

    links.querySelectorAll('.navbar-link').forEach(function (el) {
      el.addEventListener('click', close);
    });
  })();
</script>
