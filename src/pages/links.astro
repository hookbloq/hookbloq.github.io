---
import { supabase } from '../lib/supabase';
import type { Link } from '../lib/supabase';
import { loadSiteConfigs } from '../lib/site-config';

const configs = await loadSiteConfigs();
const _rawBase = import.meta.env.BASE_URL || '/';
const base = _rawBase.endsWith('/') ? _rawBase : _rawBase + '/';

const { data: links, error } = await supabase
  .from('links')
  .select('*')
  .eq('is_active', true)
  .order('sort_order', { ascending: true });

const activeLinks: Link[] = links ?? [];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HookBloq | Links</title>
    <meta name="description" content="Todos nuestros enlaces en un solo lugar" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400..700&family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />
    <meta property="og:title" content="HookBloq | Links" />
    <meta property="og:description" content="Todos nuestros enlaces en un solo lugar" />
    <meta property="og:type" content="website" />
    <style>
      :root {
        --font-display: "Space Grotesk", ui-sans-serif, system-ui, sans-serif;
        --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
        --font-mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
        --color-bg: #f5f5f0;
        --color-bg-elevated: #ffffff;
        --color-ink: #0a0a0a;
        --color-ink-muted: #6b6b6b;
        --color-ink-inverse: #fafafa;
        --color-border: #0a0a0a;
        --color-accent: #ffd400;
        --color-accent-2: #ff3b00;
        --shadow-brutal-sm: 3px 3px 0 0 #0a0a0a;
        --shadow-brutal: 6px 6px 0 0 #0a0a0a;
        --shadow-brutal-accent: 6px 6px 0 0 #ffd400;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        background: var(--color-bg);
        color: var(--color-ink);
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 8rem 0 3rem;
        background-image:
          linear-gradient(to right, rgba(10,10,10,0.04) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(10,10,10,0.04) 1px, transparent 1px);
        background-size: 48px 48px;
      }

      .container {
        width: 100%;
        max-width: 550px;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
      }

      /* ===== Profile Header ===== */
      .profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 2rem;
      }

      .profile-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 5rem;
        height: 5rem;
        margin-bottom: 1.25rem;
      }

      .profile-title {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 1.75rem;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 0.5rem;
      }

      .profile-bio {
        font-size: 0.95rem;
        color: var(--color-ink-muted);
        line-height: 1.55;
        max-width: 32ch;
      }

      .profile-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: var(--font-mono);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 0.6rem;
        padding: 0.25rem 0.65rem;
        border: 2px solid var(--color-border);
        margin-bottom: 1rem;
      }

      /* ===== Links ===== */
      .link-list {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        margin-bottom: 2rem;
      }

      .link-item {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 1rem 1.25rem;
        background: var(--color-bg-elevated);
        border: 3px solid var(--color-border);
        box-shadow: var(--shadow-brutal-sm);
        text-decoration: none;
        color: var(--color-ink);
        transition: all 0.2s ease;
        width: 100%;
      }

      .link-item:hover {
        box-shadow: var(--shadow-brutal);
        transform: translate(-3px, -3px);
      }

      .link-item:active {
        transform: translate(0, 0);
        box-shadow: var(--shadow-brutal-sm);
      }

      .link-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        font-size: 1.35rem;
        background: var(--color-bg);
        border: 2px solid var(--color-border);
      }

      .link-text {
        flex: 1;
        min-width: 0;
      }

      .link-title {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: -0.01em;
        line-height: 1.2;
      }

      .link-description {
        font-size: 0.8rem;
        color: var(--color-ink-muted);
        margin-top: 0.2rem;
        line-height: 1.3;
      }

      .link-arrow {
        flex-shrink: 0;
        font-size: 1rem;
        color: var(--color-ink-muted);
        transition: transform 0.2s ease, color 0.2s ease;
      }

      .link-item:hover .link-arrow {
        transform: translateX(3px);
        color: var(--color-ink);
      }

      /* ===== Footer ===== */
      .page-footer {
        text-align: center;
        padding: 2rem 0 0.5rem;
        font-size: 0.75rem;
        color: var(--color-ink-muted);
      }

      .page-footer a {
        color: var(--color-ink);
        font-weight: 700;
        text-decoration: none;
        font-family: var(--font-display);
        letter-spacing: -0.02em;
        transition: color 0.2s;
      }

      .page-footer a:hover {
        color: var(--color-accent-2);
      }

      .page-footer-dot {
        display: inline-flex;
        width: 6px;
        height: 6px;
        background: var(--color-accent);
        border: 1.5px solid var(--color-ink);
        margin: 0 0.5rem;
        vertical-align: middle;
      }

      /* ===== Empty state ===== */
      .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        border: 3px solid var(--color-border);
        background: var(--color-bg-elevated);
        box-shadow: var(--shadow-brutal-sm);
        width: 100%;
      }

      /* ===== Animations ===== */
      .link-item {
        opacity: 0;
        transform: translateY(20px);
        animation: slideUp 0.5s ease forwards;
      }

      @keyframes slideUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .profile {
        opacity: 0;
        animation: fadeIn 0.6s ease 0.1s forwards;
      }

      @keyframes fadeIn {
        to { opacity: 1; }
      }

      /* Stagger */
      .link-item:nth-child(1) { animation-delay: 0.2s; }
      .link-item:nth-child(2) { animation-delay: 0.27s; }
      .link-item:nth-child(3) { animation-delay: 0.34s; }
      .link-item:nth-child(4) { animation-delay: 0.41s; }
      .link-item:nth-child(5) { animation-delay: 0.48s; }
      .link-item:nth-child(6) { animation-delay: 0.55s; }
      .link-item:nth-child(7) { animation-delay: 0.62s; }
      .link-item:nth-child(8) { animation-delay: 0.69s; }
      .link-item:nth-child(9) { animation-delay: 0.76s; }
      .link-item:nth-child(10) { animation-delay: 0.83s; }
      .link-item:nth-child(11) { animation-delay: 0.90s; }
      .link-item:nth-child(12) { animation-delay: 0.97s; }

      @media (max-width: 480px) {
        body { padding: 4.5rem 0 2rem; }
        .container { padding: 0 1rem; max-width: 100%; }
        .profile-logo { width: 4rem; height: 4rem; }
        .profile-title { font-size: 1.5rem; }
        .link-item { padding: 0.85rem 1rem; }
        .link-list { padding: 0 0.25rem; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="profile">
        <div class="profile-logo" aria-hidden="true">
          <svg width="42" height="42" viewBox="0 0 54 54" xmlns="http://www.w3.org/2000/svg">
            <rect x="8" y="8" width="44" height="44" fill="#0a0a0a" />
            <rect x="2" y="2" width="44" height="44" fill="#ffd400" stroke="#0a0a0a" stroke-width="4" />
            <rect x="16" y="16" width="16" height="16" fill="#0a0a0a" />
          </svg>
        </div>
        <span class="profile-tag">
          <i class="bi bi-lightning-charge-fill"></i> Automatizacion con IA
        </span>
        <h1 class="profile-title">HookBloq</h1>
        <p class="profile-bio">Soluciones de automatizacion con inteligencia artificial. Bots, flujos de trabajo y sistemas que hacen crecer tu negocio.</p>
      </header>

      <div class="link-list">
        {
          activeLinks.length === 0 ? (
            <div class="empty-state">
              <i class="bi bi-link-45deg" style="font-size:2.5rem;color:var(--color-ink-muted);display:block;margin-bottom:0.75rem"></i>
              <p style="font-family:var(--font-mono);font-size:0.75rem;font-weight:700;text-transform:uppercase;color:var(--color-ink-muted)">Proximamente</p>
            </div>
          ) : (
            activeLinks.map((link: Link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="link-item"
              >
                {link.icon && (
                  <span class="link-icon">
                    <i class={link.icon}></i>
                  </span>
                )}
                <span class="link-text">
                  <span class="link-title">{link.title}</span>
                  {link.description && (
                    <span class="link-description">{link.description}</span>
                  )}
                </span>
                <span class="link-arrow" aria-hidden="true">
                  <i class="bi bi-arrow-up-right"></i>
                </span>
              </a>
            ))
          )
        }
      </div>

      <footer class="page-footer">
        <span>Powered by</span>
        <span class="page-footer-dot"></span>
        <a href={base} target="_blank" rel="noopener">HookBloq</a>
      </footer>
    </div>
  </body>
</html>
