---
import PublicLayout from '../../layouts/PublicLayout.astro';

const _rawBase = import.meta.env.BASE_URL || '/';
const base = _rawBase.endsWith('/') ? _rawBase : _rawBase + '/';
---

<PublicLayout title="Blog">
  <section class="hero grid-bg">
    <div class="container py-12">
      <div data-aos="fade-up">
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <span class="tag tag-accent">BLOG</span>
          <span class="section-label">Articulos</span>
        </div>
      </div>
      <h1 class="font-display hero-title mb-6" data-aos="fade-up" data-aos-delay="100" style="font-size:clamp(2.75rem,8vw,5rem)">
        IA & Automatizacion
      </h1>
      <p class="text-lg hero-subtitle mb-8" data-aos="fade-up" data-aos-delay="200">
        Articulos sobre inteligencia artificial, agentes de IA, automatizaciones con n8n y como la tecnologia puede transformar tu negocio.
      </p>
    </div>
  </section>

  <section class="section bg-surface-2">
    <div class="container">
      <div id="blog-list-mount">
        <div class="text-center py-12">
          <div class="loading-spinner" style="width:2.5rem;height:2.5rem;margin:0 auto 1rem"></div>
          <p class="text-sm text-ink-muted font-mono">Cargando articulos...</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="grid-2" style="align-items:end">
        <div data-aos="fade-up">
          <span class="section-label" style="border-color:var(--color-accent-ink);color:var(--color-accent-ink)">CONTACTO</span>
          <h2 class="font-display font-extrabold leading-tight mt-4" style="font-size:clamp(2.5rem,7vw,5rem);letter-spacing:-0.03em;color:var(--color-accent-ink)">
            Automatiza tu negocio.
          </h2>
        </div>
        <div style="display:flex;justify-content:flex-end" data-aos="fade-up" data-aos-delay="100">
          <a href={`${base}#contacto`} class="cta-btn">
            Contactanos <span style="font-size:1.2em">&#8594;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '../../lib/supabase';

    const PER_PAGE = 9;
    const _rawBase = import.meta.env.BASE_URL || '/';
    const base = _rawBase.endsWith('/') ? _rawBase : _rawBase + '/';
    const mount = document.getElementById('blog-list-mount');
    if (!mount) throw new Error('Mount point #blog-list-mount no encontrado');

    let currentPage = 1;
    let totalPages = 1;
    let articles = [];

    function tagsArray(tags) {
      if (!tags) return [];
      return tags.split(',').map(t => t.trim()).filter(Boolean);
    }

    function formatDate(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      const months = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
      return `${d.getDate().toString().padStart(2, '0')} ${months[d.getMonth()]} ${d.getFullYear()}`;
    }

    function excerptFallback(article) {
      if (article.excerpt) return article.excerpt;
      const text = article.content.replace(/<[^>]*>/g, '');
      return text.length > 120 ? text.slice(0, 120) + '...' : text;
    }

    function render() {
      if (articles.length === 0) {
        mount.innerHTML = `
          <div class="text-center py-12">
            <div class="card" style="max-width:32rem;margin:0 auto;">
              <i class="bi bi-journal-text" style="font-size:3rem;color:var(--color-ink-subtle);margin-bottom:1rem;display:block;"></i>
              <h3 class="font-display text-xl font-extrabold mb-2">No hay articulos aun</h3>
              <p class="text-sm text-ink-muted">Estamos preparando contenido sobre IA y automatizacion. Vuelve pronto.</p>
            </div>
          </div>`;
        return;
      }

      const cards = articles.map((article, index) => {
        const tags = tagsArray(article.tags).slice(0, 3);
        return `
          <a href="${base}blog/${article.slug}" class="card card-hover" style="text-decoration:none;color:inherit;display:flex;flex-direction:column;">
            ${article.featured_image
              ? `<div style="aspect-ratio:16/10;border-bottom:3px solid var(--color-border);overflow:hidden;margin:-1.5rem -1.5rem 1rem -1.5rem;">
                   <img src="${article.featured_image}" alt="${article.title}" style="width:100%;height:100%;object-fit:cover;" />
                 </div>`
              : `<div style="aspect-ratio:16/10;border-bottom:3px solid var(--color-border);overflow:hidden;margin:-1.5rem -1.5rem 1rem -1.5rem;background:var(--color-ink);display:flex;align-items:center;justify-content:center;">
                   <span class="font-display font-extrabold" style="font-size:3rem;color:var(--color-accent)">HB</span>
                 </div>`
            }
            <div class="flex items-center gap-2 mb-2 text-xs font-mono text-uppercase tracking-wide text-ink-muted">
              <span>${formatDate(article.published_at)}</span>
            </div>
            <h3 class="font-display text-lg font-extrabold leading-tight mb-2 line-clamp-2">${article.title}</h3>
            <p class="text-sm text-ink-muted line-clamp-2 mb-3">${excerptFallback(article)}</p>
            ${tags.length > 0
              ? `<div class="flex flex-wrap gap-1 mt-auto">
                   ${tags.map(t => `<span class="tag tag-default tag-sm">${t}</span>`).join('')}
                 </div>`
              : ''}
          </a>`;
      }).join('');

      let pagination = '';
      if (totalPages > 1) {
        const prevDisabled = currentPage === 1;
        const nextDisabled = currentPage === totalPages;
        pagination = `
          <div class="flex items-center justify-between mt-12 flex-wrap gap-2">
            <span class="font-mono text-sm text-ink-muted">Pag. ${currentPage} / ${totalPages}</span>
            <div class="flex items-center gap-2">
              <button id="prevBtn" class="btn btn-outline btn-sm" ${prevDisabled ? 'disabled style="opacity:0.4"' : ''}>
                <i class="bi bi-chevron-left"></i> Anterior
              </button>
              <button id="nextBtn" class="btn btn-outline btn-sm" ${nextDisabled ? 'disabled style="opacity:0.4"' : ''}>
                Siguiente <i class="bi bi-chevron-right"></i>
              </button>
            </div>
          </div>`;
      }

      mount.innerHTML = `<div class="grid-3">${cards}</div>${pagination}`;

      if (window.AOS) window.AOS.refresh();

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      if (prevBtn) prevBtn.addEventListener('click', () => { if (currentPage > 1) { currentPage--; load(); } });
      if (nextBtn) nextBtn.addEventListener('click', () => { if (currentPage < totalPages) { currentPage++; load(); } });
    }

    async function load() {
      const from = (currentPage - 1) * PER_PAGE;
      const to = from + PER_PAGE - 1;

      const { data, error, count } = await supabase
        .from('articles')
        .select('id, title, slug, excerpt, content, tags, featured_image, published_at', { count: 'exact' })
        .eq('is_published', true)
        .order('published_at', { ascending: false })
        .range(from, to);

      if (error) {
        mount.innerHTML = `<div class="card text-center"><p class="text-sm text-ink-muted">Error al cargar articulos: ${error.message}</p></div>`;
        return;
      }

      articles = data ?? [];
      totalPages = Math.max(1, Math.ceil((count ?? 0) / PER_PAGE));
      render();
    }

    load();
  </script>
</PublicLayout>
