---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const _rawBase = import.meta.env.BASE_URL || '/';
const base = _rawBase.endsWith('/') ? _rawBase : _rawBase + '/';
---

<AdminLayout title="Editar Articulo" active="articles">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/trix/1.3.1/trix.min.css" />

  <div class="flex items-center justify-between mb-8">
    <h1 class="font-display font-extrabold" style="font-size:clamp(1.75rem,4vw,2.5rem)">Editar Articulo</h1>
    <a href={`${base}admin/articles`} class="btn btn-outline"><i class="bi bi-arrow-left"></i> Volver</a>
  </div>

  <div id="alertMount"></div>

  <div id="loadingState">
    <div class="card text-center py-12">
      <div class="loading-spinner" style="margin:0 auto 1rem;width:2rem;height:2rem"></div>
      <p class="text-sm text-ink-muted font-mono">Cargando articulo...</p>
    </div>
  </div>

  <form id="articleForm" class="card" style="display:none">
    <input type="hidden" id="articleId" />
    <input type="hidden" id="originalTitle" />
    <div class="grid-2 mb-4">
      <div class="form-group">
        <label class="form-label" for="title">Titulo <span style="color:var(--color-accent-2)">*</span></label>
        <input class="form-input" id="title" name="title" type="text" required />
      </div>
      <div class="form-group">
        <label class="form-label" for="tags">Tags (separados por coma)</label>
        <input class="form-input" id="tags" name="tags" type="text" placeholder="IA, n8n, Automatizacion..." />
      </div>
    </div>

    <div class="form-group mb-4">
      <label class="form-label" for="excerpt">Extracto (max 300 caracteres)</label>
      <textarea class="form-textarea" id="excerpt" name="excerpt" rows="2" maxlength="300"></textarea>
    </div>

    <div class="form-group mb-4">
      <label class="form-label" for="featured_image">URL de imagen destacada</label>
      <input class="form-input" id="featured_image" name="featured_image" type="text" placeholder="https://..." />
    </div>

    <div class="form-group mb-4">
      <label class="form-label" for="content">Contenido <span style="color:var(--color-accent-2)">*</span></label>
      <input id="content" name="content" type="hidden" />
      <trix-editor input="content"></trix-editor>
    </div>

    <div class="form-group mb-6">
      <div class="form-checkbox">
        <input type="checkbox" id="is_published" name="is_published" value="1" />
        <label class="form-label" for="is_published" style="margin-bottom:0;">Publicado</label>
      </div>
    </div>

    <div class="flex gap-2">
      <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">Actualizar articulo <span style="font-size:1.2em">&#8594;</span></button>
      <a href={`${base}admin/articles`} class="btn btn-outline btn-lg">Cancelar</a>
    </div>
  </form>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/trix/1.3.1/trix.min.js"></script>
  <script>
    import { supabase } from '../../../lib/supabase';
    import { getLoginUrl } from '../../../lib/auth';
    import { generateUniqueSlug } from '../../../lib/slugify';

    const _rawBase = import.meta.env.BASE_URL || '/';
    const base = _rawBase.endsWith('/') ? _rawBase : _rawBase + '/';
    const form = document.getElementById('articleForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const alertMount = document.getElementById('alertMount')!;
    const loadingState = document.getElementById('loadingState')!;

    function showMsg(msg: string, type: 'success' | 'error' = 'success') {
      alertMount.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
      if (type === 'success') setTimeout(() => { alertMount.innerHTML = ''; }, 4000);
    }

    function escapeHtml(s: string): string {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[c]!));
    }

    // Extraer el ID del query param: /admin/articles/edit?id=123
    const urlParams = new URLSearchParams(window.location.search);
    const articleId = urlParams.get('id');

    async function init() {
      if (!articleId) {
        loadingState.style.display = 'none';
        showMsg('ID de articulo no especificado en la URL', 'error');
        return;
      }

      const { data: { session } } = await supabase.auth.getSession();
      if (!session?.user) {
        window.location.href = getLoginUrl();
        return;
      }
      (window as any).__supabaseClient = supabase;

      const { data: article, error } = await supabase
        .from('articles')
        .select('*')
        .eq('id', Number(articleId))
        .maybeSingle();

      if (error || !article) {
        loadingState.style.display = 'none';
        showMsg('Articulo no encontrado', 'error');
        return;
      }

      // Rellenar el form
      (document.getElementById('articleId') as HTMLInputElement).value = String(article.id);
      (document.getElementById('originalTitle') as HTMLInputElement).value = article.title;
      (document.getElementById('title') as HTMLInputElement).value = article.title;
      (document.getElementById('tags') as HTMLInputElement).value = article.tags ?? '';
      (document.getElementById('excerpt') as HTMLTextAreaElement).value = article.excerpt ?? '';
      (document.getElementById('featured_image') as HTMLInputElement).value = article.featured_image ?? '';
      (document.getElementById('is_published') as HTMLInputElement).checked = article.is_published;

      // Trix: esperar a que el editor este listo
      const trixEditor = document.querySelector('trix-editor') as any;
      const hiddenInput = document.getElementById('content') as HTMLInputElement;
      hiddenInput.value = article.content;

      // Trix carga el contenido del input al inicializar, pero si ya se inicializo
      // antes de setear el value, necesitamos inyectarlo manualmente
      if (trixEditor && trixEditor.editor) {
        trixEditor.editor.loadHTML(article.content);
      } else {
        // Esperar al evento trix-initialize
        document.addEventListener('trix-initialize', () => {
          const editor = document.querySelector('trix-editor') as any;
          if (editor?.editor) editor.editor.loadHTML(article.content);
        }, { once: true });
      }

      loadingState.style.display = 'none';
      form.style.display = 'block';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = Number((document.getElementById('articleId') as HTMLInputElement).value);
      const originalTitle = (document.getElementById('originalTitle') as HTMLInputElement).value;
      const title = (document.getElementById('title') as HTMLInputElement).value.trim();
      const tags = (document.getElementById('tags') as HTMLInputElement).value.trim();
      const excerpt = (document.getElementById('excerpt') as HTMLTextAreaElement).value.trim() || null;
      const featured_image = (document.getElementById('featured_image') as HTMLInputElement).value.trim() || null;
      const content = (document.getElementById('content') as HTMLInputElement).value;
      const is_published = (document.getElementById('is_published') as HTMLInputElement).checked;

      if (!title) { showMsg('El titulo es obligatorio', 'error'); return; }
      if (!content || !content.trim()) { showMsg('El contenido es obligatorio', 'error'); return; }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="loading-spinner"></span> Actualizando...';

      try {
        const update: Record<string, any> = {
          title,
          excerpt,
          content,
          featured_image,
          tags: tags || null,
          is_published,
        };

        // Si cambio el titulo, regenerar slug
        if (title !== originalTitle) {
          update.slug = await generateUniqueSlug(title, id);
        }

        // Si se publica por primera vez, setear published_at
        if (is_published) {
          const { data: current } = await supabase.from('articles').select('published_at').eq('id', id).maybeSingle();
          if (current && !current.published_at) {
            update.published_at = new Date().toISOString();
          }
        }

        const { error } = await supabase.from('articles').update(update).eq('id', id);
        if (error) throw error;

        showMsg('Articulo actualizado exitosamente. Redirigiendo...', 'success');
        setTimeout(() => { window.location.href = base + 'admin/articles'; }, 1200);
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'Error desconocido';
        showMsg('Error al actualizar: ' + msg, 'error');
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Actualizar articulo <span style="font-size:1.2em">&#8594;</span>';
      }
    });

    init().catch((err) => {
      loadingState.style.display = 'none';
      showMsg('Error: ' + (err.message || 'desconocido'), 'error');
    });
  </script>
</AdminLayout>
